{
  "name": "maispace/mai-gallery",
  "description": "Bilder-Galerie & Rückblicke TYPO3 Extension",
  "type": "typo3-cms-extension",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Joel Maximilian Mai",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4",
    "typo3/cms-extbase": "^13.4",
    "typo3/cms-fluid": "^13.4"
  },
  "require-dev": {
    "typo3/testing-framework": "^8.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Maispace\\MaiGallery\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Maispace\\MaiGallery\\Tests\\": "Tests/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mai_gallery"
    },
    "branch-alias": {
      "dev-main": "13.0.x-dev"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    }
  }
}
